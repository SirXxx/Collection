# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ─── 虚拟环境 ──────────────────────────────────────────────────────────────────
.venv/
venv/
env/
.env

# ─── 运行时输出（可重新生成，不入库）────────────────────────────────────────────

# 股票筛选：导出结果
stock/*.csv
stock/*.xlsx

# 股票筛选：运行时数据库（每次运行自动创建）
stock/*.db

# 股票筛选：用户定时配置（机器特定，不共享）
stock/scheduler_config.json

# 股票筛选：输出目录
stock/output/

# 基金分析：输出目录（含 cache/）
fund/output/

# NPPA：接口调试输出
nppa/output/

# tools：调试输出
tools/*.txt
tools/*.json

# ─── IDE & 系统 ───────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
Thumbs.db
.DS_Store
desktop.ini

# ─── 敏感配置（含 token / 密钥的本地覆盖）──────────────────────────────────────
*.local.json
*.secret.*
